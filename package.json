{
	"name": "hris-app-vanaila",
	"private": true,
	"version": "1.2.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"e2e:bootstrap:local": "node scripts/e2e/bootstrap-local-supabase.mjs",
		"qa:schema-discipline": "node scripts/qa/schema-discipline-check.mjs",
		"qa:bootstrap-grants": "node scripts/qa/bootstrap-grants-check.mjs",
		"qa:rls-audit": "node scripts/qa/rls-policy-audit.mjs",
		"qa:migrations": "node scripts/qa/migration-safety-check.mjs",
		"qa:negative": "node scripts/qa/rls-negative-path.mjs",
		"qa:stress:seed": "node scripts/qa/stress-seed.mjs",
		"qa:stress:seed:average": "node scripts/qa/stress-seed.mjs --profile average --employees 120",
		"qa:stress:seed:busy": "node scripts/qa/stress-seed.mjs --profile busy --employees 220",
		"qa:e2e": "playwright test",
		"qa:e2e:stress": "playwright test tests/stress-workload.spec.js",
		"qa:e2e:ui": "playwright test --ui",
		"qa:hardening": "npm run qa:schema-discipline && npm run qa:migrations && npm run qa:rls-audit && npm run qa:bootstrap-grants"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@tailwindcss/vite": "^4.2.2",
		"dotenv": "^17.4.1",
		"pg": "^8.16.3",
		"tailwindcss": "^4.2.2",
		"vite": "^7.3.1",
		"vite-plugin-compression": "^0.5.1"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.97.0",
		"chart.js": "^4.5.1",
		"exceljs": "^4.4.0",
		"jspdf": "^4.2.0",
		"jspdf-autotable": "^5.0.7",
		"sweetalert2": "^11.26.20"
	}
}
